  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "fast-check": "^3.21.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
