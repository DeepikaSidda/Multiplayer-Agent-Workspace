# ------------------------------------------------------------------------------
# Multiplayer Agent Workspace — example environment configuration
# Copy to `.env` and fill in your own values. DO NOT commit real secrets.
# ------------------------------------------------------------------------------

# ---- Server (server/) --------------------------------------------------------
# HTTP + WebSocket port the server listens on.
PORT=8787
# SQLite database file path (created automatically).
DB_PATH=maw.db

# ---- AI agent (Amazon Bedrock — Nova Pro) ------------------------------------
# The agent teammate uses Amazon Bedrock (model: amazon.nova-pro-v1:0).
# Set a region to ENABLE the agent. If unset, the app still runs but @mentioning
# an agent will not call a model.
AWS_REGION=us-east-1
# Optional alternative that takes precedence over AWS_REGION for the agent.
# BEDROCK_REGION=us-east-1

# AWS credentials are read via the standard AWS SDK provider chain. Prefer a
# shared profile or an IAM role over inline keys. Example (placeholders only):
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
# AWS_PROFILE=default

# ---- Client (client/) — optional overrides -----------------------------------
# Where the browser client reaches the server. Defaults shown; only set these
# if you change the server host/port.
# VITE_SERVER_HTTP=http://localhost:8787
# VITE_SERVER_WS=ws://localhost:8787/ws
